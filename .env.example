# Environment Configuration for AI Decision Service
# Copy this file to .env and fill in your actual values

# Database Configuration
# MongoDB Atlas URI - format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/CapstoneDatabase?retryWrites=true&w=majority
MONGODB_DB=CapstoneDatabase

# Supabase Configuration
# Use your Supabase project URL and anon key here for backend access.
# If your frontend environment uses NEXT_PUBLIC_*, copy those values here without the prefix.
SUPABASE_URL=https://oxxlmtgxdjbpfdsorsrx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im94eGxtdGd4ZGpicGZkc29yc3J4Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY0ODQxOTIsImV4cCI6MjA5MjA2MDE5Mn0.eBvhYd7rgKdt2l8hb4P0TsfeAMDTCmrllHEXYxCNVwQ
# Server Configuration
PORT=10000
HOST=0.0.0.0
ENV=production

# CORS and Security
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://malabon-smartflood.vercel.app,https://malabon-smartflood.vercel.app/relief

# Comma-separated list of trusted hosts
TRUSTED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Logging
LOG_LEVEL=INFO
