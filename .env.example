# Environment Configuration for AI Decision Service
# Copy this file to .env and fill in your actual values

# Database Configuration
# MongoDB Atlas URI - format: mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/disaster_management?retryWrites=true

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# Server Configuration
PORT=10000
HOST=0.0.0.0
ENV=production

# CORS and Security
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# Comma-separated list of trusted hosts
TRUSTED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Logging
LOG_LEVEL=INFO
